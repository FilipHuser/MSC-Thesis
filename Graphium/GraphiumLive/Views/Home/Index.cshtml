@{
    ViewData["Title"] = "Graphium Live";
}

<!DOCTYPE html>
<html>
<head>
    <title>Graphium Live</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.0/signalr.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
    <style>
        * {
            box-sizing: border-box;
        }

        body {
            background: #f8f9fa;
            color: #212529;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            margin: 0;
            padding: 24px;
        }

        h1 {
            font-size: 1.1rem;
            font-weight: 600;
            color: #212529;
            margin: 0 0 20px;
            display: flex;
            align-items: center;
            gap: 8px;
            letter-spacing: -0.01em;
        }

        #status {
            display: inline-block;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #dee2e6;
            flex-shrink: 0;
        }

            #status.connected {
                background: #20c997;
            }

        .charts {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
        }

        .chart-box {
            background: #ffffff;
            border: 1px solid #e9ecef;
            border-radius: 10px;
            padding: 14px 16px;
            flex: 1 1 400px;
            min-width: 0;
        }

            .chart-box h3 {
                margin: 0 0 10px;
                font-size: 0.75rem;
                font-weight: 500;
                color: #6c757d;
                text-transform: uppercase;
                letter-spacing: 0.05em;
            }

            .chart-box canvas {
                max-height: 200px;
            }

        .text-signals {
            margin-top: 12px;
            background: #ffffff;
            border: 1px solid #e9ecef;
            border-radius: 10px;
            overflow: hidden;
        }

        .text-row {
            display: flex;
            gap: 16px;
            padding: 8px 16px;
            border-bottom: 1px solid #f1f3f5;
            font-size: 0.82rem;
        }

            .text-row:last-child {
                border-bottom: none;
            }

            .text-row span:first-child {
                color: #adb5bd;
                width: 140px;
                flex-shrink: 0;
                font-size: 0.78rem;
            }

            .text-row span:last-child {
                color: #495057;
                font-family: 'Consolas', 'SF Mono', monospace;
            }
    </style>
</head>
<body>
    <h1><span id="status"></span>Graphium Live</h1>
    <div class="charts" id="charts"></div>
    <div class="text-signals" id="textSignals"></div>

    <script>
        const MAX_POINTS = 500;
        const charts = {};
        const textSignals = {};

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/livedata")
            .withAutomaticReconnect()
            .build();

        connection.on("ReceiveData", (json) => {
            const data = JSON.parse(json);
            const t = data.t;
            const signals = data.s;

            for (const [name, value] of Object.entries(signals)) {
                if (typeof value === "number") {
                    updateChart(name, t, value);
                } else {
                    updateText(name, value);
                }
            }
        });

        connection.onreconnecting(() => document.getElementById("status").classList.remove("connected"));
        connection.onreconnected(() => document.getElementById("status").classList.add("connected"));

        connection.start().then(() => {
            document.getElementById("status").classList.add("connected");
        });

        function updateChart(name, t, value) {
            if (!charts[name]) {
                const box = document.createElement("div");
                box.className = "chart-box";
                box.innerHTML = `<h3>${name}</h3><canvas id="chart_${name}" style="height:200px"></canvas>`;
                document.getElementById("charts").appendChild(box);

                const ctx = document.getElementById(`chart_${name}`).getContext("2d");
                charts[name] = new Chart(ctx, {
                    type: "line",
                    data: {
                        labels: [],
                        datasets: [{
                            label: name,
                            data: [],
                            borderColor: "#339af0",
                            backgroundColor: "rgba(51,154,240,0.06)",
                            borderWidth: 1.5,
                            pointRadius: 0,
                            fill: false,
                            tension: 0.2
                        }]
                    },
                    options: {
                        animation: false,
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            x: { display: false },
                            y: {
                                ticks: { color: "#adb5bd", font: { size: 11 } },
                                grid: { color: "#f1f3f5" },
                                border: { display: false }
                            }
                        },
                        plugins: { legend: { display: false } }
                    }
                });
            }

            const chart = charts[name];
            chart.data.labels.push(t.toFixed(0));
            chart.data.datasets[0].data.push(value);

            if (chart.data.labels.length > MAX_POINTS) {
                chart.data.labels.shift();
                chart.data.datasets[0].data.shift();
            }

            chart.update("none");
        }

        function updateText(name, value) {
            if (!textSignals[name]) {
                const row = document.createElement("div");
                row.className = "text-row";
                row.id = `text_${name}`;
                row.innerHTML = `<span>${name}</span><span id="textval_${name}"></span>`;
                document.getElementById("textSignals").appendChild(row);
                textSignals[name] = true;
            }
            document.getElementById(`textval_${name}`).textContent = JSON.stringify(value);
        }
    </script>
</body>
</html>