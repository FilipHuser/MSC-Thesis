<UserControl x:Class="Graphium.Controls.NumericSignalControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:controls="clr-namespace:Graphium.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="50"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#F5F5F5" BorderBrush="#DDD" BorderThickness="0,0,1,0">
            <TextBlock Text="{Binding SignalBase.Name}"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       FontSize="10" Foreground="#555">
                <TextBlock.LayoutTransform>
                    <RotateTransform Angle="-90"/>
                </TextBlock.LayoutTransform>
            </TextBlock>
        </Border>

        <ContentControl Grid.Column="1" Content="{Binding PlotControl, Mode=OneTime}"/>

        <Border Grid.Column="2" BorderBrush="#DDD" BorderThickness="1,0,0,0">
            <controls:YAxisControl MinY="{Binding YMin}" MaxY="{Binding YMax}"/>
        </Border>
    </Grid>
</UserControl>