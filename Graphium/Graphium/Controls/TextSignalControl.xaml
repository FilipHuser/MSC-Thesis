<UserControl x:Class="Graphium.Controls.TextSignalControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border BorderBrush="#DDD" BorderThickness="0,0,0,1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="50"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#F5F5F5" BorderBrush="#DDD" BorderThickness="0,0,1,0">
                <TextBlock Text="{Binding SignalBase.Name}"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           FontSize="10" Foreground="#555">
                    <TextBlock.LayoutTransform>
                        <RotateTransform Angle="-90"/>
                    </TextBlock.LayoutTransform>
                </TextBlock>
            </Border>

            <Grid Grid.Column="1" Margin="8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
               Text="{Binding LastTime, StringFormat={}{0:F0}ms}"
               Foreground="#999" FontSize="11"
               VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
               Text="{Binding LastValue}"
               Foreground="#222" FontSize="11"
               VerticalAlignment="Center"
               TextWrapping="Wrap"/>
            </Grid>

            <Border Grid.Column="2" Background="#F5F5F5" BorderBrush="#DDD" BorderThickness="1,0,0,0"/>
        </Grid>
    </Border>
</UserControl>