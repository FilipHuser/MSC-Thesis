<UserControl x:Class="Graphium.Controls.DataPlotterControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:b="clr-namespace:Graphium.Behaviors"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Rectangle HorizontalAlignment="Stretch" 
                   VerticalAlignment="Stretch"
                   Fill="Transparent"
                   Stroke="DarkGray" 
                   StrokeThickness="1"
                   StrokeDashArray="4,4"/>

        <!-- Placeholder -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Visualizers.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <TextBlock Text="No signals configured" Foreground="DarkGray" FontSize="14" HorizontalAlignment="Center"/>
            <TextBlock Text="Add signals via Data Acquisition" Foreground="#999" FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Grid with splitters via Behavior -->
        <Grid>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Visualizers.Count}" Value="0">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <i:Interaction.Behaviors>
                <b:VisualizerGridBehavior Visualizers="{Binding Visualizers}"/>
            </i:Interaction.Behaviors>
        </Grid>
    </Grid>
</UserControl>