@{
    ViewData["Title"] = "Home Page";
}

@using SharpPcap;
@model MonitorSettingsViewModel;

@if (Model == null)
{
    <div class="card mt-4">
        <div class="card-header">
            <h5 class="card-title">Packet Capture Configuration</h5>
        </div>
        <div class="card-body">
            <form asp-action="CapturePackets" method="post">
                <div class="mb-3">
                    <label for="deviceSelect" class="form-label">Select a Capture Device:</label>
                    <select asp-for="CaptureDeviceIndex" id="deviceSelect" class="form-select" required>
                        @{
                            int i = 0;
                        }
                        @foreach (var dev in (CaptureDeviceList)ViewBag.devices)
                        {
                            <option value="@i">@dev.Description</option>
                            i++;
                        }
                    </select>
                </div> 

                <div class="mb-3">
                    <label for="filterInput" class="form-label">Packet Filter:</label>
                    <input asp-for="Filter" type="text" id="filterInput" class="form-control" placeholder="Enter a filter (e.g., tcp, udp, port 80) [Berkeley Packet Filters]" />
                </div>

                <div class="mb-3">
                    <label for="readTimeoutInput" class="form-label">Read Timeout (ms):</label>
                    <input asp-for="ReadTimeout" type="number" id="readTimeoutInput" class="form-control" placeholder="Enter read timeout in milliseconds" />
                </div>

                <div class="mb-3">
                    <label for="packetsToFetchInput" class="form-label">Number of packets to fetch:</label>
                    <input asp-for="NPacketsPerFetch" type="number" id="packetsToFetchInput" class="form-control" placeholder="Enter number of packets to fetch" min="1" max="100" />
                </div>
                <button type="submit" class="btn btn-primary">Start capturing</button>
            </form>
        </div>
    </div>
}

<div class="card mt-4">
    <div class="card-body">
        <div class="mt-3">
            <label for="fetchFrequency" class="form-label">Data Fetch Frequency (ms):</label>
            <input type="range" id="fetchFrequency" class="form-range" min="100" max="5000" step="100" value="1000" />
            <div class="d-flex justify-content-between">
                <small>100 ms</small>
                <small>5000 ms</small>
            </div>
        </div>
    </div>
</div>

<div class="card mt-4">
    <canvas id="packetChart" width="400" height="200"></canvas>
</div>

@section Scripts {
    <script>
        let fetchInterval = 1000; // Default fetch interval in milliseconds
        let startTime = Date.now(); // Record the start time
        let chartData = []; // Array to store fetched data

        // Update the fetch frequency based on range input
        document.getElementById("fetchFrequency").addEventListener("input", function () {
            fetchInterval = parseInt(this.value);
            if (fetchTimer) {
                clearInterval(fetchTimer);
                startFetchInterval();
            }
        });

        let fetchTimer;

        function startFetchInterval() {
            fetchTimer = setInterval(fetchPacketData, fetchInterval);
        }

        async function fetchPacketData() {
            try {
                // Fetch packet data from the server
                const response = await fetch('/Home/_FetchPacketsPartial');
                if (!response.ok) {
                    throw new Error(`HTTP error! Status: ${response.status}`);
                }

                const fetchedData = await response.json();

                // Add new data points to the chartData array
                const currentTime = (Date.now() - startTime) / 1000; // Elapsed time in seconds
                fetchedData.forEach(value => {
                    chartData.push({ x: currentTime, y: value });
                });

                // Update the chart with new data
                updateChart();
            } catch (error) {
                console.error('Error fetching packet data:', error);
            }
        }

        // Initialize Chart.js
        const ctx = document.getElementById('packetChart').getContext('2d');
        const packetChart = new Chart(ctx, {
            type: 'scatter', // Use scatter plot
            data: {
                datasets: [{
                    label: 'Packet Data',
                    data: chartData,
                    backgroundColor: 'rgba(75, 192, 192, 0.2)',
                    borderColor: 'rgba(75, 192, 192, 1)',
                    borderWidth: 1,
                    showLine: true // Connect points with a line (optional)
                }]
            },
            options: {
                scales: {
                    x: {
                        type: 'linear',
                        position: 'bottom',
                        title: {
                            display: true,
                            text: 'Time Elapsed (s)'
                        }
                    },
                    y: {
                        title: {
                            display: true,
                            text: 'Packet Value'
                        }
                    }
                }
            }
        });

        function updateChart() {
            packetChart.update();
        }

        // Start the automatic fetching
        startFetchInterval();
    </script>
}
