<Window x:Class="FHMA.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FHMA"
        mc:Ignorable="d"
        Title="FHMA" Height="450" Width="500"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal">

            <Button Grid.Column="0"
                    Content="Add Biometric Signal"
                    Padding="5"
                    Click="Button_AddBiometricSignal"/>

            <GridSplitter  Width="10"/>

            <Button Grid.Column="0"
                    Content="Load Configuration"
                    Padding="5"
                    Click="Button_LoadConfiguration"/>

        </StackPanel>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding BiometricSignals}"
                  Margin="0 10"
                  IsReadOnly="True"
                  CanUserResizeColumns="False"
                  CanUserResizeRows="False"
                  CanUserSortColumns="False"
                  CanUserReorderColumns="False"
                  GridLinesVisibility="None"
                  AutoGenerateColumns="False"
                  HeadersVisibility="Column">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Biometric Signal"
                                    Width="*"
                                    Binding="{Binding}"/>

                <DataGridTemplateColumn Header="Actions"
                                        Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>

                            <StackPanel Orientation="Horizontal">
                                <Button Content="⚙️"/>

                                <Button Content="🗑️"
                                        Click="Button_RemoveGraph"/>
                            </StackPanel>
                            
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
                
        </DataGrid>
        
        <Grid Grid.Row="2"
              Width="auto">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Orientation="Horizontal">

                <Button Grid.Column="0"
                        Content="Save Configuration"
                        Padding="5"
                        Click="Button_SaveConfiguration"/>

                <GridSplitter  Width="10"/>

                <Button Grid.Column="0"
                        Content="Start Capturing"
                        Padding="5"
                        Click="Button_StartCapturing"/>
            </StackPanel>

            <StackPanel Grid.Column="1" 
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right">

                <Label Content="Occupied channels:"/>
                <TextBlock VerticalAlignment="Center"
                           Text="{Binding GraphCount}"/>
            </StackPanel>
        </Grid>
        
    </Grid>
</Window>
